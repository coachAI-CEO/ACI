generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GameModelId {
  COACHAI
  POSSESSION
  PRESSING
  TRANSITION
}

enum Phase {
  ATTACKING
  DEFENDING
  TRANSITION
  TRANSITION_TO_ATTACK
  TRANSITION_TO_DEFEND
}

enum Zone {
  DEFENSIVE_THIRD
  MIDDLE_THIRD
  ATTACKING_THIRD
}

enum SpaceConstraint {
  FULL
  HALF
  THIRD
  QUARTER
}

enum PlayerLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum CoachLevel {
  GRASSROOTS
  USSF_C
  USSF_B_PLUS
}

enum DrillType {
  WARMUP
  TECHNICAL
  TACTICAL
  CONDITIONED_GAME
  FULL_GAME
  COOLDOWN
}

enum ArtifactType {
  DRILL
  SESSION
  MICROCYCLE
  MESOCYCLE
}

model Drill {
  id    String @id @default(uuid())
  title String

  // Tactical & psych metadata
  principleIds  Json? // array of strings
  psychThemeIds Json? // array of strings

  // Physical / conditioning
  energySystem String? // "ATP-PC" | "Anaerobic" | "Aerobic"
  rpeMin       Int?
  rpeMax       Int?

  // Session constraints
  numbersMin      Int?
  numbersMax      Int?
  spaceConstraint String?
  goalsAvailable  Int?
  goalMode        String?

  // Formation & level metadata
  formationUsed String?
  playerLevel   PlayerLevel?
  coachLevel    CoachLevel?

  // Drill type metadata
  drillType DrillType?

  // GK metadata
  needGKFocus Boolean? @default(false)
  gkFocus     String?

  gameModelId GameModelId
  phase       Phase
  zone        Zone
  ageGroup    String
  durationMin Int?
  qaScore     Float?
  approved    Boolean     @default(false)
  savedToVault Boolean    @default(false) // Vault system: mark drills saved to vault

  json           Json
  visualThumbSvg String?
  visualHash     String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  qaReports QAReport[] @relation("DrillQAReports")
  
  @@index([savedToVault])
  @@index([gameModelId, ageGroup, phase, zone])
}

model Session {
  id    String @id @default(uuid())
  title String

  // Tactical & psych metadata
  principleIds  Json? // array of strings
  psychThemeIds Json? // array of strings

  // Physical / conditioning
  energySystem String? // "ATP-PC" | "Anaerobic" | "Aerobic"
  rpeMin       Int?
  rpeMax       Int?

  // Session constraints
  numbersMin      Int?
  numbersMax      Int?
  spaceConstraint String?
  goalsAvailable  Int?
  goalMode        String?

  // Formation & level metadata
  formationUsed String?
  playerLevel   PlayerLevel?
  coachLevel    CoachLevel?

  gameModelId GameModelId
  phase       Phase?
  zone        Zone?
  ageGroup    String
  durationMin Int? // Total session duration (60 or 90 minutes)
  qaScore     Float?
  approved    Boolean     @default(false)
  savedToVault Boolean    @default(false) // Vault system: mark sessions saved to vault
  isSeries    Boolean     @default(false) // Vault system: is this part of a series?
  seriesId     String?     // Vault system: if part of series, link to series group
  seriesNumber Int?        // Vault system: position in series (1, 2, 3, etc.)

  json           Json
  visualThumbSvg String?
  visualHash     String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  qaReports QAReport[] @relation("SessionQAReports")
  skillFocuses SkillFocus[]
  
  @@index([savedToVault])
  @@index([isSeries, seriesId])
  @@index([gameModelId, ageGroup, phase, zone])
}

model SkillFocus {
  id         String   @id @default(uuid())
  sessionId  String?
  seriesId   String?
  sessionIds Json?
  title      String
  summary    String?
  keySkills  Json
  coachingPoints Json?
  psychologyGood Json?
  psychologyBad  Json?
  sectionPhrases Json?
  createdAt  DateTime @default(now())

  session Session? @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([seriesId])
}

model QAReport {
  id           String       @id @default(uuid())
  artifactId   String
  artifactType ArtifactType @default(DRILL)
  drillId      String?
  sessionId    String?
  drill        Drill?       @relation("DrillQAReports", fields: [drillId], references: [id], onDelete: Cascade)
  session      Session?     @relation("SessionQAReports", fields: [sessionId], references: [id], onDelete: Cascade)
  pass         Boolean
  scores       Json
  summary      String?
  createdAt    DateTime     @default(now())

  @@index([artifactId, artifactType])
  @@index([drillId])
  @@index([sessionId])
}

model ArtifactEmbedding {
  id           String                @id @default(uuid())
  artifactType ArtifactType
  artifactId   String
  dims         Int
  embedding    Unsupported("vector")
  createdAt    DateTime              @default(now())

  @@index([artifactType, artifactId])
}

// Admin metrics tracking
model ApiMetrics {
  id              String   @id @default(uuid())
  
  // What was generated
  operationType   String   // "session", "drill", "series", "skill_focus", "qa_review"
  artifactId      String?  // Link to session/drill ID if applicable
  
  // LLM metrics
  model           String   // "gemini-3-flash-preview", "gemini-2.5-flash"
  promptTokens    Int?     // Input tokens
  completionTokens Int?    // Output tokens
  totalTokens     Int?     // Total tokens
  promptLength    Int      // Prompt character length
  responseLength  Int?     // Response character length
  
  // Timing
  durationMs      Int      // How long the API call took
  
  // Status
  success         Boolean  @default(true)
  errorMessage    String?
  
  // Metadata
  ageGroup        String?
  gameModelId     String?
  phase           String?
  
  createdAt       DateTime @default(now())
  
  @@index([operationType])
  @@index([createdAt])
  @@index([model])
  @@index([success])
}

// Daily aggregated metrics for fast dashboard queries
model DailyMetrics {
  id              String   @id @default(uuid())
  date            DateTime @db.Date @unique
  
  // Counts
  totalApiCalls   Int      @default(0)
  successfulCalls Int      @default(0)
  failedCalls     Int      @default(0)
  
  // By operation type
  sessionsGenerated    Int @default(0)
  drillsGenerated      Int @default(0)
  seriesGenerated      Int @default(0)
  skillFocusGenerated  Int @default(0)
  qaReviewsRun         Int @default(0)
  
  // Tokens
  totalPromptTokens     Int @default(0)
  totalCompletionTokens Int @default(0)
  totalTokens           Int @default(0)
  
  // Timing
  totalDurationMs       Int @default(0)
  avgDurationMs         Int @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([date])
}
