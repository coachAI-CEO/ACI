generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GameModelId {
  COACHAI
  POSSESSION
  PRESSING
  TRANSITION
}

enum Phase {
  ATTACKING
  DEFENDING
  TRANSITION
  TRANSITION_TO_ATTACK
  TRANSITION_TO_DEFEND
}

enum Zone {
  DEFENSIVE_THIRD
  MIDDLE_THIRD
  ATTACKING_THIRD
}

enum SpaceConstraint {
  FULL
  HALF
  THIRD
  QUARTER
}

enum PlayerLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum CoachLevel {
  GRASSROOTS
  USSF_C
  USSF_B_PLUS
}

enum DrillType {
  WARMUP
  TECHNICAL
  TACTICAL
  CONDITIONED_GAME
  FULL_GAME
  COOLDOWN
}

enum ArtifactType {
  DRILL
  SESSION
  MICROCYCLE
  MESOCYCLE
}

model Drill {
  id    String @id @default(uuid())
  title String

  // Tactical & psych metadata
  principleIds  Json? // array of strings
  psychThemeIds Json? // array of strings

  // Physical / conditioning
  energySystem String? // "ATP-PC" | "Anaerobic" | "Aerobic"
  rpeMin       Int?
  rpeMax       Int?

  // Session constraints
  numbersMin      Int?
  numbersMax      Int?
  spaceConstraint String?
  goalsAvailable  Int?
  goalMode        String?

  // Formation & level metadata
  formationUsed String?
  playerLevel   PlayerLevel?
  coachLevel    CoachLevel?

  // Drill type metadata
  drillType DrillType?

  // GK metadata
  needGKFocus Boolean? @default(false)
  gkFocus     String?

  gameModelId GameModelId
  phase       Phase
  zone        Zone
  ageGroup    String
  durationMin Int?
  qaScore     Float?
  approved    Boolean     @default(false)

  json           Json
  visualThumbSvg String?
  visualHash     String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  qaReports QAReport[] @relation("DrillQAReports")
}

model Session {
  id    String @id @default(uuid())
  title String

  // Tactical & psych metadata
  principleIds  Json? // array of strings
  psychThemeIds Json? // array of strings

  // Physical / conditioning
  energySystem String? // "ATP-PC" | "Anaerobic" | "Aerobic"
  rpeMin       Int?
  rpeMax       Int?

  // Session constraints
  numbersMin      Int?
  numbersMax      Int?
  spaceConstraint String?
  goalsAvailable  Int?
  goalMode        String?

  // Formation & level metadata
  formationUsed String?
  playerLevel   PlayerLevel?
  coachLevel    CoachLevel?

  gameModelId GameModelId
  phase       Phase?
  zone        Zone?
  ageGroup    String
  durationMin Int? // Total session duration (60 or 90 minutes)
  qaScore     Float?
  approved    Boolean     @default(false)

  json           Json
  visualThumbSvg String?
  visualHash     String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  qaReports QAReport[] @relation("SessionQAReports")
}

model QAReport {
  id           String       @id @default(uuid())
  artifactId   String
  artifactType ArtifactType @default(DRILL)
  drillId      String?
  sessionId    String?
  drill        Drill?       @relation("DrillQAReports", fields: [drillId], references: [id], onDelete: Cascade)
  session      Session?     @relation("SessionQAReports", fields: [sessionId], references: [id], onDelete: Cascade)
  pass         Boolean
  scores       Json
  summary      String?
  createdAt    DateTime     @default(now())

  @@index([artifactId, artifactType])
  @@index([drillId])
  @@index([sessionId])
}

model ArtifactEmbedding {
  id           String                @id @default(uuid())
  artifactType ArtifactType
  artifactId   String
  dims         Int
  embedding    Unsupported("vector")
  createdAt    DateTime              @default(now())

  @@index([artifactType, artifactId])
}
