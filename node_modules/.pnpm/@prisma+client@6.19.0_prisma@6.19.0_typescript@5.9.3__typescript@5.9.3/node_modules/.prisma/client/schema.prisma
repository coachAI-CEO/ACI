generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GameModelId {
  COACHAI
  POSSESSION
  PRESSING
  TRANSITION
}

enum Phase {
  ATTACKING
  DEFENDING
  TRANSITION
  TRANSITION_TO_ATTACK
  TRANSITION_TO_DEFEND
}

enum Zone {
  DEFENSIVE_THIRD
  MIDDLE_THIRD
  ATTACKING_THIRD
}

enum SpaceConstraint {
  FULL
  HALF
  THIRD
  QUARTER
}

enum PlayerLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum CoachLevel {
  GRASSROOTS
  USSF_C
  USSF_B_PLUS
}

enum UserRole {
  FREE
  COACH
  CLUB
  ADMIN
  TRIAL
}

enum SubscriptionPlan {
  FREE
  COACH_BASIC
  COACH_PRO
  CLUB_STANDARD
  CLUB_PREMIUM
  TRIAL
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  TRIAL
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  MODERATOR
  SUPPORT
}

enum DrillType {
  WARMUP
  TECHNICAL
  TACTICAL
  CONDITIONED_GAME
  FULL_GAME
  COOLDOWN
}

enum ArtifactType {
  DRILL
  SESSION
  MICROCYCLE
  MESOCYCLE
}

model Drill {
  id      String  @id @default(uuid())
  refCode String? @unique // Human-readable reference code (D-XXXX format)
  title   String

  // Tactical & psych metadata
  principleIds  Json? // array of strings
  psychThemeIds Json? // array of strings

  // Physical / conditioning
  energySystem String? // "ATP-PC" | "Anaerobic" | "Aerobic"
  rpeMin       Int?
  rpeMax       Int?

  // Session constraints
  numbersMin      Int?
  numbersMax      Int?
  spaceConstraint String?
  goalsAvailable  Int?
  goalMode        String?

  // Formation & level metadata
  formationUsed String?
  playerLevel   PlayerLevel?
  coachLevel    CoachLevel?

  // Drill type metadata
  drillType DrillType?

  // GK metadata
  needGKFocus Boolean? @default(false)
  gkFocus     String?

  gameModelId   GameModelId
  phase         Phase
  zone          Zone
  ageGroup      String
  durationMin   Int?
  qaScore       Float?
  approved      Boolean     @default(false)
  savedToVault  Boolean     @default(false) // Vault system: mark drills saved to vault
  favoriteCount Int         @default(0) // Number of users who favorited this drill

  json           Json
  visualThumbSvg String?
  visualHash     String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  qaReports QAReport[] @relation("DrillQAReports")

  @@index([refCode])
  @@index([savedToVault])
  @@index([gameModelId, ageGroup, phase, zone])
}

model Session {
  id      String  @id @default(uuid())
  refCode String? @unique // Human-readable reference code (S-XXXX or SR-XXXX format)
  title   String

  // Tactical & psych metadata
  principleIds  Json? // array of strings
  psychThemeIds Json? // array of strings

  // Physical / conditioning
  energySystem String? // "ATP-PC" | "Anaerobic" | "Aerobic"
  rpeMin       Int?
  rpeMax       Int?

  // Session constraints
  numbersMin      Int?
  numbersMax      Int?
  spaceConstraint String?
  goalsAvailable  Int?
  goalMode        String?

  // Formation & level metadata
  formationUsed String?
  playerLevel   PlayerLevel?
  coachLevel    CoachLevel?

  gameModelId   GameModelId
  phase         Phase?
  zone          Zone?
  ageGroup      String
  durationMin   Int? // Total session duration (60 or 90 minutes)
  qaScore       Float?
  approved      Boolean     @default(false)
  savedToVault  Boolean     @default(false) // Vault system: mark sessions saved to vault
  isSeries      Boolean     @default(false) // Vault system: is this part of a series?
  seriesId      String? // Vault system: if part of series, link to series group
  seriesNumber  Int? // Vault system: position in series (1, 2, 3, etc.)
  favoriteCount Int         @default(0) // Number of users who favorited this session

  json           Json
  visualThumbSvg String?
  visualHash     String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  qaReports    QAReport[]   @relation("SessionQAReports")
  skillFocuses SkillFocus[]

  @@index([refCode])
  @@index([savedToVault])
  @@index([isSeries, seriesId])
  @@index([gameModelId, ageGroup, phase, zone])
}

model SkillFocus {
  id             String   @id @default(uuid())
  sessionId      String?
  seriesId       String?
  sessionIds     Json?
  title          String
  summary        String?
  keySkills      Json
  coachingPoints Json?
  psychologyGood Json?
  psychologyBad  Json?
  sectionPhrases Json?
  createdAt      DateTime @default(now())

  session Session? @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([seriesId])
}

model QAReport {
  id           String       @id @default(uuid())
  artifactId   String
  artifactType ArtifactType @default(DRILL)
  drillId      String?
  sessionId    String?
  drill        Drill?       @relation("DrillQAReports", fields: [drillId], references: [id], onDelete: Cascade)
  session      Session?     @relation("SessionQAReports", fields: [sessionId], references: [id], onDelete: Cascade)
  pass         Boolean
  scores       Json
  summary      String?
  createdAt    DateTime     @default(now())

  @@index([artifactId, artifactType])
  @@index([drillId])
  @@index([sessionId])
}

model ArtifactEmbedding {
  id           String                @id @default(uuid())
  artifactType ArtifactType
  artifactId   String
  dims         Int
  embedding    Unsupported("vector")
  createdAt    DateTime              @default(now())

  @@index([artifactType, artifactId])
}

// Admin metrics tracking
model ApiMetrics {
  id String @id @default(uuid())

  // What was generated
  operationType String // "session", "drill", "series", "skill_focus", "qa_review"
  artifactId    String? // Link to session/drill ID if applicable
  userId        String? // Link to user who generated this (for usage tracking)
  user          User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // LLM metrics
  model            String // "gemini-3-flash-preview", "gemini-2.5-flash"
  promptTokens     Int? // Input tokens
  completionTokens Int? // Output tokens
  totalTokens      Int? // Total tokens
  promptLength     Int // Prompt character length
  responseLength   Int? // Response character length

  // Timing
  durationMs Int // How long the API call took

  // Status
  success      Boolean @default(true)
  errorMessage String?

  // Metadata
  ageGroup    String?
  gameModelId String?
  phase       String?

  createdAt DateTime @default(now())

  @@index([operationType])
  @@index([createdAt])
  @@index([model])
  @@index([success])
  @@index([userId])
}

// Daily aggregated metrics for fast dashboard queries
model DailyMetrics {
  id   String   @id @default(uuid())
  date DateTime @unique @db.Date

  // Counts
  totalApiCalls   Int @default(0)
  successfulCalls Int @default(0)
  failedCalls     Int @default(0)

  // By operation type
  sessionsGenerated   Int @default(0)
  drillsGenerated     Int @default(0)
  seriesGenerated     Int @default(0)
  skillFocusGenerated Int @default(0)
  qaReviewsRun        Int @default(0)

  // Tokens
  totalPromptTokens     Int @default(0)
  totalCompletionTokens Int @default(0)
  totalTokens           Int @default(0)

  // Timing
  totalDurationMs Int @default(0)
  avgDurationMs   Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
}

// User model with authentication and subscription support
model User {
  id           String  @id @default(uuid())
  email        String? @unique // Optional for backward compatibility, required for authenticated users
  passwordHash String? // bcrypt hashed password (null for anonymous users)
  name         String?

  // User role and subscription
  role                  UserRole           @default(FREE)
  subscriptionPlan      SubscriptionPlan   @default(FREE)
  subscriptionStatus    SubscriptionStatus @default(ACTIVE)
  subscriptionStartDate DateTime?
  subscriptionEndDate   DateTime?
  trialEndDate          DateTime? // For trial users

  // Profile
  coachLevel       CoachLevel?
  organizationName String?
  teamAgeGroups    String[] // Age groups they coach (e.g., ["U10", "U12"])

  // Usage tracking
  sessionsGeneratedThisMonth Int      @default(0)
  drillsGeneratedThisMonth   Int      @default(0)
  lastResetDate              DateTime @default(now())

  // Email verification
  emailVerified   Boolean   @default(false)
  emailVerifiedAt DateTime?

  // Activity tracking
  lastLoginAt DateTime?

  // Admin fields
  adminRole       AdminRole?
  adminNotes      String?
  lastAdminAction DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  favorites               Favorite[]
  refreshTokens           RefreshToken[]
  emailVerificationTokens EmailVerificationToken[]
  adminActions            AdminAction[]
  userSessions            UserSession[]
  apiMetrics              ApiMetrics[]
  playerPlans             PlayerPlan[]
  calendarEvents          CalendarEvent[]
}

// Favorites - allows users to save sessions, drills, or series
model Favorite {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Polymorphic reference - only one will be set per favorite
  sessionId String? // References Session.id
  drillId   String? // References Drill.id
  seriesId  String? // References Session.seriesId for series groups

  createdAt DateTime @default(now())

  // Ensure a user can only favorite each item once
  @@unique([userId, sessionId])
  @@unique([userId, drillId])
  @@unique([userId, seriesId])
  @@index([userId])
  @@index([sessionId])
  @@index([drillId])
  @@index([seriesId])
}

// Refresh tokens for JWT authentication
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

// Email verification tokens
model EmailVerificationToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email     String // Store email at time of token creation
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@index([email])
}

// Audit log for admin actions
model AdminAction {
  id      String @id @default(uuid())
  adminId String
  admin   User   @relation(fields: [adminId], references: [id], onDelete: Cascade)

  action       String // "user.deleted", "session.approved", "subscription.changed"
  resourceType String? // "User", "Session", "Drill", etc.
  resourceId   String? // ID of affected resource
  details      Json? // Additional action details

  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([action])
  @@index([resourceType, resourceId])
  @@index([createdAt])
}

// User sessions for analytics
model UserSession {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// Player-only training plans (adapted from sessions/series)
model PlayerPlan {
  id      String  @id @default(uuid())
  refCode String? @unique // P-XXXX format
  userId  String // Who created/owns this plan
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Source reference
  sourceType    String // "SESSION" | "SERIES"
  sourceId      String // sessionId or seriesId
  sourceRefCode String? // For easy lookup

  // Plan metadata
  title       String
  ageGroup    String
  playerLevel PlayerLevel? // Inherited from source session/series
  objectives  String? // Short summary of what player will work on
  durationMin Int // Total plan duration

  // Adapted content
  json      Json // Array of solo drills with simplified instructions
  equipment Json? // Minimal equipment list (e.g., ["ball", "cones", "wall"])

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([sourceType, sourceId])
  @@index([refCode])
}

// Calendar events - scheduled training sessions
model CalendarEvent {
  id     String @id @default(uuid())
  userId String // Who owns this calendar event
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // What session is scheduled
  sessionId      String // References Session.id
  sessionRefCode String? // For easy reference

  // When it's scheduled
  scheduledDate DateTime // Date and time of the training session
  durationMin   Int? // Override session duration if needed

  // Additional context
  notes    String? // Coach notes for this specific session
  location String? // Training location (field, facility, etc.)
  teamName String? // Which team/group this is for

  // Status
  completed Boolean @default(false) // Mark as completed after session
  cancelled Boolean @default(false) // Mark as cancelled

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([sessionId])
  @@index([scheduledDate])
  @@index([userId, scheduledDate])
}
